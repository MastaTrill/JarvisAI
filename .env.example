# JarvisAI Environment Configuration Template
# Copy this file to .env and fill in your values

# ========================================
# Azure Configuration (for deployment)
# ========================================
AZURE_ENV_NAME=dev
AZURE_LOCATION=eastus
AZURE_SUBSCRIPTION_ID=your-subscription-id-here

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://username:password@localhost:5432/jarvisai
DATABASE_ADMIN_LOGIN=jarvisadmin
DATABASE_ADMIN_PASSWORD=your-secure-password-here

# ========================================
# Redis Configuration
# ========================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ========================================
# Application Configuration
# ========================================
SECRET_KEY=your-secret-key-here-generate-with-openssl-rand-hex-32
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=True

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ========================================
# Azure Services (populated after deployment)
# ========================================
AZURE_KEY_VAULT_ENDPOINT=
APPLICATIONINSIGHTS_CONNECTION_STRING=
AZURE_CONTAINER_REGISTRY_ENDPOINT=

# ========================================
# Authentication & Security
# ========================================
JWT_SECRET_KEY=your-jwt-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OAuth Configuration (if using OAuth)
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=

# ========================================
# External Services
# ========================================
# AWS S3 (if using cloud storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Slack (if using notifications)
SLACK_WEBHOOK_URL=
SLACK_TOKEN=

# ========================================
# Machine Learning Configuration
# ========================================
MODEL_STORAGE_PATH=./models
DATA_STORAGE_PATH=./data
MLFLOW_TRACKING_URI=
WANDB_API_KEY=

# ========================================
# Rate Limiting
# ========================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ========================================
# Background Jobs
# ========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ========================================
# Monitoring & Observability
# ========================================
ENABLE_METRICS=True
ENABLE_TRACING=True
OTEL_EXPORTER_OTLP_ENDPOINT=

# ========================================
# Feature Flags
# ========================================
ENABLE_WEBSOCKETS=True
ENABLE_ADMIN_DASHBOARD=True
ENABLE_API_DOCS=True
